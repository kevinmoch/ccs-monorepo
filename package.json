{
  "name": "ccs-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ssl": "node scripts/dev.mjs --ssl",
    "build": "turbo run build",
    "build:web": "node scripts/build-web.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "build:android": "node scripts/build-android.mjs",
    "doc": "cd documents && npx http-server -p 8081 --gzip --cors",
    "doc:ssl": "cd documents && npx http-server -p 8080 --gzip --cors --ssl -C cert.pem -K key.pem",
    "upload": "pnpm --filter @ccs/upload start",
    "upload:ssl": "cross-env UPLOAD_PORT=8083 UPLOAD_TLS_CERT=documents/cert.pem UPLOAD_TLS_KEY=documents/key.pem tsx packages/upload/src/server.ts",
    "preview": "node scripts/preview-ssl.mjs",
    "lint": "turbo run lint",
    "test": "vitest run",
    "ccs": "pnpm --filter @ccs/cli ccs"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "cross-env": "^10.1.0",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "workbox-build": "^7.4.1"
  }
}
