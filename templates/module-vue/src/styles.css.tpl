body{margin:0;font-family:Inter,ui-sans-serif,system-ui}.module-shell{min-height:100%;color:var(--ccs-text,#0f172a)}.module-header{display:flex;align-items:center;justify-content:space-between;gap:18px;margin-bottom:22px}.module-header span{font-size:12px;color:color-mix(in srgb,var(--ccs-text,#0f172a) 58%,transparent)}.module-header h2{margin:4px 0 0}.module-header nav{display:flex;gap:10px;flex-wrap:wrap}.module-header a{padding:8px 12px;border-radius:10px;color:inherit;text-decoration:none}.module-header a.router-link-active{background:color-mix(in srgb,var(--ccs-primary,#2563eb) 14%,transparent);color:var(--ccs-primary,#2563eb)}.module-home{min-height:280px;display:grid;align-content:center;gap:10px;padding:24px;border:1px solid color-mix(in srgb,var(--ccs-text,#0f172a) 10%,transparent);border-radius:16px;background:color-mix(in srgb,var(--ccs-bg,#fff) 92%,white)}.module-home p{margin:0;color:color-mix(in srgb,var(--ccs-text,#0f172a) 58%,transparent);font-weight:700}.module-home h1{margin:0;font-size:clamp(30px,6vw,48px)}.module-home span{color:color-mix(in srgb,var(--ccs-text,#0f172a) 68%,transparent)}
